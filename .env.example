# ── OpenAI ──────────────────────────────────────────────────────────────────
# Your OpenAI API key (used for Whisper STT and GPT-4)
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── ElevenLabs ───────────────────────────────────────────────────────────────
# Your ElevenLabs API key
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Voice ID to use for TTS (default: "Rachel" - 21m00Tcm4TlvDq8ikWAM)
# Browse voices at: https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Emily Persona ────────────────────────────────────────────────────────────
# The system prompt that shapes Emily's personality and teaching style.
# Customize this to change how Emily interacts with students.
EMILY_SYSTEM_PROMPT=You are Emily, a warm and encouraging English tutor. You engage students in natural conversation while gently correcting grammatical mistakes, explaining vocabulary, and offering example sentences. Adapt your language level to the student. Keep responses concise (2-4 sentences) and always end with a question or prompt to keep the conversation going.
